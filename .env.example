# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — OPTIONAL overrides. By default api/checkout.js resolves
# prices via Stripe lookup keys on active prices (team_annual, team_perpetual,
# org_annual, org_perpetual), so price rotations need no env changes. Set these
# only to pin an explicit price ID.
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_TEAM_PERPETUAL=price_...
STRIPE_PRICE_ORG_ANNUAL=price_...
STRIPE_PRICE_ORG_PERPETUAL=price_...

# License key signing (RSA private key, base64 or PEM)
LICENSE_PRIVATE_KEY=

# Email delivery (Zoho SMTP)
SMTP_USER=hello@ragvault.net
SMTP_PASSWORD=

# Site URL (for CORS and redirect URLs)
SITE_URL=https://www.ragvault.net
